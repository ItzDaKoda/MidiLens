# MidiLens does not require an API key for the built-in MIDI analyzer.
# This is here as a safe placeholder if you add an external music, cloud storage, or AI service later.
VITE_OPTIONAL_API_KEY=

# Leave blank for Vercel/local proxy deployment. Use only if your backend is hosted separately.
# Example: VITE_API_URL=https://your-backend.example.com/api/analyze
VITE_API_URL=
